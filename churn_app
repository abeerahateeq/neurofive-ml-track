      "source": [
        "# Run the Streamlit app in the background and expose it via localtunnel\n",
        "import subprocess\n",
        "import threading\n",
        "import time\n",
        "import socket\n",
        "\n",
        "def run_streamlit():\n",
        "    # Use 'app.py' located inside the 'churn_app' directory\n",
        "    cmd = [\"streamlit\", \"run\", \"churn_app/app.py\", \"--server.port\", \"8501\", \"--server.enableCORS\", \"false\", \"--server.enableXsrfProtection\", \"false\"]\n",
        "    p = subprocess.Popen(cmd)\n",
        "    p.wait()\n",
        "\n",
        "def run_localtunnel(port):\n",
        "    print(f\"Starting localtunnel for port {port}...\")\n",
        "    subprocess.run([\"lt\", \"--port\", str(port), \"--subdomain\", \"colab-streamlit-churn-predictor\"]) # You can change 'colab-streamlit-churn-predictor' to a unique name\n",
        "\n",
        "# Start Streamlit in a separate thread\n",
        "print(\"Starting Streamlit app...\")\n",
        "streamlit_thread = threading.Thread(target=run_streamlit)\n",
        "streamlit_thread.daemon = True\n",
        "streamlit_thread.start()\n",
        "\n",
        "# Give Streamlit a moment to start up\n",
        "time.sleep(5)\n",
        "\n",
        "# Check if port 8501 is open\n",
        "def is_port_open(port):\n",
        "    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n",
        "    result = sock.connect_ex(('127.0.0.1', port))\n",
        "    sock.close()\n",
        "    return result == 0\n",
        "\n",
        "if is_port_open(8501):\n",
        "    print(\"Streamlit app is running on port 8501.\")\n",
        "    # Start localtunnel in the main thread\n",
        "    run_localtunnel(8501)\n",
        "else:\n",
        "    print(\"Streamlit app did not start on port 8501. Please check the logs.\")"
      ],
